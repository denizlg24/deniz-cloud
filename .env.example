# Docker Compose environment variables

# ── PostgreSQL ──
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=denizcloud
POSTGRES_PORT=5433

# ── MongoDB ──
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
MONGO_PORT=27018
MONGO_SYNC_USER=sync_reader
MONGO_SYNC_PASSWORD=

# ── Meilisearch ──
MEILI_MASTER_KEY=
MEILI_PORT=7700
MEILI_ENV=production
MEILI_DATA_DIR=/mnt/ssd/meilisearch

# ── Redis ──
REDIS_PASSWORD=
REDIS_PORT=6380
REDIS_DATA_DIR=/mnt/ssd/redis
REDIS_MAXMEMORY=128mb
REDIS_ADMIN_URL=redis://default:password@redis:6379
REDIS_INTERNAL_HOST=redis:6379
REDIS_EXTERNAL_HOST=redis.denizlg24.com:6380

# ── Auth (shared by storage + admin APIs) ──
JWT_SECRET=
TOTP_ENCRYPTION_KEY=

# ── Storage service ──
SSD_STORAGE_PATH=/mnt/ssd/storage
HDD_STORAGE_PATH=/mnt/hdd/storage
SSD_WATERMARK_PERCENT=90
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=eu-west-1
S3_ENDPOINT=https://storage.denizlg24.com/v2
S3_ROOT_PATH=/data/ssd/.s3-v2
S3_TEMP_PATH=/data/ssd/.s3-v2-temp

